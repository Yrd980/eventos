{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@eventos/contracts": ["packages/contracts/src/index.ts"],
      "@eventos/shared": ["packages/shared/src/index.ts"],
      "@eventos/config": ["packages/config/src/index.ts"]
    }
  }
}
