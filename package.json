{
  "name": "eventos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter @eventos/api dev",
    "dev:api": "bun --filter @eventos/api dev",
    "dev:realtime": "bun --filter @eventos/realtime dev",
    "dev:cms": "bun --filter @eventos/cms dev",
    "dev:web": "bun --filter @eventos/web-miniapp dev",
    "db:migrate": "bun --filter @eventos/api db:migrate",
    "db:seed:smoke": "bun --filter @eventos/api db:seed:smoke",
    "typecheck": "bun tsc -b",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write ."
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "typescript": "5.8.3"
  }
}
